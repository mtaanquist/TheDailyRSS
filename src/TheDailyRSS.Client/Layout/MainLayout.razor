@inherits LayoutComponentBase
@implements IDisposable
@inject AppState State
@inject IJSRuntime JS

<div class="tdr-app">
    <div class="tdr-mobile-top">
        <button class="burger" @onclick="() => _navOpen = !_navOpen" aria-label="Menu">☰</button>
        <a class="mt-title" href="/">
            <span class="mt-brand">The Daily RSS</span>
            @if (!string.IsNullOrEmpty(State.HeaderDate))
            {
                <span class="mt-date">@State.HeaderDate</span>
            }
        </a>
        <a class="burger" href="/saved" aria-label="Read later"><Icon Name="bookmark" Size="20" /></a>
    </div>

    <div class="tdr-body">
        <Sidebar Open="_navOpen" OnNavigate="@(() => _navOpen = false)" />
        @if (_navOpen)
        {
            <div class="tdr-scrim" @onclick="() => _navOpen = false"></div>
        }
        <main class="tdr-main">
            @Body
        </main>
    </div>
</div>

@code {
    private bool _navOpen;
    private DotNetObjectReference<MainLayout>? _ref;

    protected override void OnInitialized() => State.Changed += OnStateChanged;
    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        _ref = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("tdrHotkeys.register", _ref);
        await JS.InvokeVoidAsync("tdrScroll.init");
    }

    [JSInvokable] public Task OnRefreshHotkey() => State.RequestReloadAsync();

    public void Dispose()
    {
        State.Changed -= OnStateChanged;
        _ = JS.InvokeVoidAsync("tdrHotkeys.unregister");
        _ref?.Dispose();
    }
}
