@inherits LayoutComponentBase

<div class="tdr-app">
    <div class="tdr-mobile-top">
        <button class="burger" @onclick="() => _navOpen = !_navOpen" aria-label="Menu">☰</button>
        <div class="mt-title">The Daily RSS</div>
        <a class="burger" href="/saved" aria-label="Saved">★</a>
    </div>

    <div class="tdr-body">
        <Sidebar Open="_navOpen" OnNavigate="@(() => _navOpen = false)" />
        @if (_navOpen)
        {
            <div class="tdr-scrim" @onclick="() => _navOpen = false"></div>
        }
        <main class="tdr-main">
            @Body
        </main>
    </div>

    <footer class="tdr-footer">
        <span>© @DateTime.Now.Year Mads Taanquist</span>
        <a href="https://github.com/mtaanquist/TheDailyRSS" target="_blank" rel="noopener noreferrer">GitHub ↗</a>
    </footer>
</div>

@code {
    private bool _navOpen;
}
