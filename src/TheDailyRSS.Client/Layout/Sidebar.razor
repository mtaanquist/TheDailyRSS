@implements IDisposable
@inject AppState State
@inject ApiClient Api
@inject AuthService Auth
@inject NavigationManager Nav

<nav class="tdr-sidebar @(Open ? "open" : "")">
    @if (Auth.CurrentUser is { } user)
    {
        <div class="tdr-acct">
            <a class="tdr-acct-link" href="/settings/profile">
                <div class="tdr-avatar">@user.Initials</div>
                <div class="who">
                    <div class="nm">@user.DisplayName</div>
                    <div class="em">@user.Email</div>
                </div>
            </a>
            <button class="tdr-acct-signout" @onclick="SignOut" title="Sign out" aria-label="Sign out">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M14 8V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-2" />
                    <path d="M9 12h12" />
                    <path d="M18 9l3 3-3 3" />
                </svg>
            </button>
        </div>
    }

    <div class="tdr-sidebar-label">Feeds</div>

    <button class="tdr-feed-item special @(IsActive(null, false) ? "active" : "")" @onclick="@(() => GoSection(null, false))">
        <Icon Name="newspaper" Size="14" />
        <span class="name">Today's stories</span>
        @if (ShowUnread)
        {
            <span class="count">@State.UnreadTotal</span>
        }
    </button>
    <button class="tdr-feed-item special @(IsActive(null, true) ? "active" : "")" @onclick="@(() => GoSection(null, true))">
        <Icon Name="bookmark" Size="14" />
        <span class="name">Read later</span>
    </button>
    <button class="tdr-feed-item special @(_activeHidden ? "active" : "")" @onclick="GoHidden">
        <Icon Name="eye-off" Size="14" />
        <span class="name">Hidden</span>
    </button>
    <button class="tdr-feed-item special @(_activeTickers ? "active" : "")" @onclick="@(() => Go("/tickers"))">
        <Icon Name="trending-up" Size="14" />
        <span class="name">Markets</span>
    </button>

    @if (AiOn)
    {
        <button class="tdr-feed-item special @(_activeBriefing ? "active" : "")" @onclick="@(() => Go("/briefing"))">
            <Icon Name="sparkles" Size="14" />
            <span class="name">Daily briefing</span>
        </button>
        <button class="tdr-feed-item special @(_activeWeekly ? "active" : "")" @onclick="@(() => Go("/weekly"))">
            <Icon Name="calendar" Size="14" />
            <span class="name">The Weekly</span>
        </button>
    }

    <div class="tdr-sidebar-divider"></div>

    @foreach (var c in State.Categories.Where(c => c.FeedCount > 0))
    {
        var active = IsActive(c.Id, false);
        var expanded = _expanded.Contains(c.Id);
        <div>
            <div class="tdr-feed-item @(active ? "active" : "")">
                <button class="tdr-folder-toggle" @onclick="() => ToggleExpand(c.Id)" aria-label="Toggle folder">
                    <Icon Name="@(expanded ? "chevron-down" : "chevron-right")" Size="12" />
                </button>
                <span class="tdr-feed-dot" style="background:@c.Color"></span>
                <button class="tdr-folder-name" @onclick="@(() => GoSection(c.Slug, false))">
                    <span class="name">@c.Name</span>
                    @if (ShowUnread)
                    {
                        <span class="count">@c.UnreadCount</span>
                    }
                </button>
            </div>
            @if (expanded && _feedsByCat.TryGetValue(c.Id, out var feeds))
            {
                <div class="tdr-subfeeds">
                    @foreach (var f in feeds)
                    {
                        <button class="tdr-subfeed @(_activeSrc == f.SourceId ? "active" : "")"
                                @onclick="@(() => GoSource(f.SourceId))">
                            <span class="name">@f.Title</span>
                            @if (ShowUnread)
                            {
                                <span class="count">@f.UnreadCount</span>
                            }
                        </button>
                    }
                    @if (feeds.Count == 0)
                    {
                        <div class="tdr-subfeed" style="font-style:italic">no sources</div>
                    }
                </div>
            }
        </div>
    }

    <button class="tdr-addfeed" @onclick="() => _showAdd = true"><Icon Name="plus" Size="13" /> add feed</button>

    <div class="tdr-sidebar-foot">
        <a href="/feeds">Manage feeds</a>
        <a href="/settings/profile">Preferences</a>
    </div>

    <div class="tdr-sidebar-colophon">
        <a class="gh" href="https://github.com/mtaanquist/TheDailyRSS" target="_blank" rel="noopener noreferrer">
            <Icon Name="github" Size="13" /> GitHub
        </a>
    </div>
</nav>

<AddFeedDialog @bind-Visible="_showAdd" Categories="State.Categories"
               DefaultCategoryId="_activeCat" OnAdded="OnFeedAdded" />

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback OnNavigate { get; set; }

    private bool ShowUnread => Auth.CurrentUser?.Preferences.ShowUnread ?? true;
    private bool AiOn => Auth.CurrentUser?.Preferences.AiEnabled ?? false;

    private bool _showAdd;
    private Guid? _activeCat;
    private Guid? _activeSrc;
    private bool _activeSaved;
    private bool _activeHidden;
    private bool _activeBriefing;
    private bool _activeWeekly;
    private bool _activeTickers;
    private readonly HashSet<Guid> _expanded = new();
    private readonly Dictionary<Guid, List<FeedDto>> _feedsByCat = new();

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnStateChanged;
        Nav.LocationChanged += OnLocationChanged;
        Auth.AuthChanged += OnAuthChanged;
        await LoadSelectionAsync();
    }

    /// <summary>Loads categories + reads the active section. The sidebar's chrome renders inside the
    /// layout even for not-yet-authenticated visitors (AuthorizeRouteView puts NotAuthorized content in
    /// the layout); calling protected APIs then would 401 and trip Blazor's error UI, so we wait for sign-in.</summary>
    private async Task LoadSelectionAsync()
    {
        if (Auth.CurrentUser is null) return;
        await State.EnsureLoadedAsync();
        ReadSelection(); // needs categories loaded to map the URL slug → category
        await EnsureActiveExpandedAsync();
    }

    private async void OnAuthChanged()
    {
        await LoadSelectionAsync();
        await InvokeAsync(StateHasChanged);
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        ReadSelection();
        await EnsureActiveExpandedAsync();
        StateHasChanged();
    }

    private void ReadSelection()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var seg = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Split('/', StringSplitOptions.RemoveEmptyEntries);
        var first = seg.Length > 0 ? seg[0] : "";
        _activeSaved = first == "saved";
        _activeHidden = first == "hidden";
        _activeBriefing = first == "briefing";
        _activeWeekly = first == "weekly";
        _activeTickers = first == "tickers";
        _activeCat = EditionRoutes.CategoryIdForSlug(State.Categories, first);
        _activeSrc = Guid.TryParse(EditionRoutes.QueryValue(uri.Query, "src"), out var s) ? s : null;
    }

    /// <summary>The archived date in the current URL (2nd path segment), if any.</summary>
    private DateOnly? CurrentDate()
    {
        var seg = Nav.ToBaseRelativePath(Nav.Uri).Split('?')[0].Split('/', StringSplitOptions.RemoveEmptyEntries);
        return seg.Length == 2 && DateOnly.TryParse(seg[1], out var d) ? d : null;
    }

    /// <summary>Auto-expand the folder for the section being read so its sources are visible.</summary>
    private async Task EnsureActiveExpandedAsync()
    {
        if (_activeCat is { } id)
        {
            _expanded.Add(id);
            await LoadFeedsAsync(id);
        }
    }

    private async Task ToggleExpand(Guid catId)
    {
        if (!_expanded.Add(catId)) { _expanded.Remove(catId); return; }
        await LoadFeedsAsync(catId);
    }

    private async Task LoadFeedsAsync(Guid catId)
    {
        if (_feedsByCat.ContainsKey(catId)) return;
        try { _feedsByCat[catId] = await Api.GetFeedsAsync(catId); }
        catch { _feedsByCat[catId] = new(); }
    }

    private bool IsActive(Guid? cat, bool saved) =>
        !_activeHidden && !_activeBriefing && !_activeWeekly && !_activeTickers && _activeSaved == saved && _activeCat == cat;

    private async Task GoHidden()
    {
        Nav.NavigateTo("/hidden");
        await OnNavigate.InvokeAsync();
    }

    /// <summary>Navigate to a fixed pseudo-section route (briefing / weekly) and close the mobile menu.</summary>
    private async Task Go(string path)
    {
        Nav.NavigateTo(path);
        await OnNavigate.InvokeAsync();
    }

    /// <summary>Navigate to a section by slug (null = today's front page), keeping the current date.
    /// Re-clicking "Today's stories" reloads the edition from the database, mirroring a masthead-title click.</summary>
    private async Task GoSection(string? slug, bool saved)
    {
        var isToday = !saved && string.IsNullOrEmpty(slug);
        Nav.NavigateTo(EditionRoutes.Path(saved ? "saved" : isToday ? "today" : slug!, saved ? null : CurrentDate()));
        await OnNavigate.InvokeAsync();
        if (isToday)
            await State.RequestReloadAsync();
    }

    /// <summary>Read just one source's stories (front page, filtered to that source).</summary>
    private async Task GoSource(Guid sourceId)
    {
        var date = CurrentDate();
        Nav.NavigateTo(EditionRoutes.Path("today", date) + $"?src={sourceId}");
        await OnNavigate.InvokeAsync();
    }

    private async Task OnFeedAdded()
    {
        await State.RefreshAsync();
        // Refresh any open folders so new sources / counts show.
        _feedsByCat.Clear();
        foreach (var id in _expanded.ToList())
            await LoadFeedsAsync(id);
    }

    private async Task SignOut()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", replace: true);
    }

    public void Dispose()
    {
        State.Changed -= OnStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        Auth.AuthChanged -= OnAuthChanged;
    }
}
