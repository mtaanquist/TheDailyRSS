@page "/weekly"
@page "/weekly/{Date}"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject AuthService Auth
@inject AppState State
@inject NavigationManager Nav

<PageTitle>The Weekly · The Daily RSS</PageTitle>

<header class="tdr-masthead">
    <div class="tdr-masthead-meta">
        <span>The Weekly</span>
        <span>@RangeLabel(WeekStart, WeekEnd)</span>
    </div>
    <h1 class="tdr-masthead-title">The Weekly</h1>
    <div class="tdr-masthead-rule"><span>— your week, in review —</span></div>
</header>

@if (AiOn)
{
    <div class="tdr-editionbar">
        <button class="tdr-navbtn" disabled="@(_prevSunday is null || _loading)" @onclick="@(() => Go(_prevSunday))">← <span class="lbl">earlier</span></button>
        <span class="tdr-edition-date">@(_isLatest ? "THIS WEEK" : RangeLabel(WeekStart, WeekEnd))</span>
        <button class="tdr-navbtn" disabled="@(_nextSunday is null || _loading)" @onclick="@(() => Go(_nextSunday))"><span class="lbl">later</span> →</button>
        @if (!_isLatest)
        {
            <button class="tdr-navbtn" @onclick="GoLatest"><span class="lbl">latest</span> »</button>
        }
    </div>
}

<div class="tdr-edition-body @(_loading ? "loading" : "")">
    @if (!AiOn)
    {
        <div class="tdr-empty">
            <div class="tdr-empty-mark">∅</div>
            <h1 class="tdr-empty-title">AI briefings are off</h1>
            <p class="tdr-empty-sub">Turn them on, then add your endpoint &amp; key — The Weekly is written for you each Saturday night.</p>
            <a class="tdr-btn" href="/settings/ai">open AI settings</a>
        </div>
    }
    else if (_error is not null)
    {
        <div class="tdr-error">@_error</div>
        <button class="tdr-btn" @onclick="Generate" disabled="@_loading">try again</button>
    }
    else if (_summary is null)
    {
        @if (_loading)
        {
            <AiWritingIndicator Message="The editor is writing The Weekly"
                                Hint="Reviewing the whole week — this can take a few minutes on a local model." />
        }
        else
        {
            <div class="tdr-empty">
                <div class="tdr-empty-mark">∅</div>
                <h1 class="tdr-empty-title">@(_isLatest ? "This week isn't out yet" : "No edition for this week")</h1>
                <p class="tdr-empty-sub">
                    @(_isLatest
                        ? "The Weekly is written automatically on Saturday night, ready for Sunday — or write it now."
                        : "This week wasn't written up. Compose it now from that week's stories.")
                </p>
                <button class="tdr-btn" @onclick="Generate">write The Weekly</button>
            </div>
        }
    }
    else
    {
        var ed = _summary;
        <div class="tdr-toolbar">
            <span class="title">The Weekly</span>
            <span class="spacer"></span>
            <span class="tdr-hint" style="margin:0">@ed.ArticleCount stories · @ed.Model</span>
            <button class="tdr-link muted" @onclick="Generate" disabled="@_loading">regenerate</button>
        </div>

        <AiDigest Content="@ed.Content" />

        <div class="tdr-hint">Generated @ed.GeneratedAt.LocalDateTime.ToString("MMM d, HH:mm") · AI can be wrong — check the originals.</div>
    }
</div>

@code {
    [Parameter] public string? Date { get; set; }

    private AiSummaryDto? _summary;
    private bool _loading;
    private string? _error;
    private string _loadedKey = "";
    private CancellationTokenSource? _pollCts;

    // "The Weekly" is delivered on a Sunday and covers the preceding Monday–Saturday. We navigate by
    // that delivery Sunday: each step is the previous/next Sunday. Seeded to a valid Sunday up front so
    // WeekStart/WeekEnd (which subtract days) are safe on the first render, before Resolve() runs.
    private DateOnly _sunday = DeliverySunday(DateOnly.FromDateTime(DateTime.Today)); // the active edition's delivery Sunday
    private DateOnly _currentSunday;   // the most recent delivery Sunday (the latest edition)
    private DateOnly? _prevSunday;     // ← earlier (null at the start of the archive)
    private DateOnly? _nextSunday;     // later → (null when already latest)
    private bool _isLatest;

    private DateOnly WeekStart => _sunday.AddDays(-6); // Monday
    private DateOnly WeekEnd => _sunday.AddDays(-1);   // Saturday

    private bool AiOn => Auth.CurrentUser?.Preferences.AiEnabled ?? false;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnStateChanged;
        await State.EnsureLoadedAsync();
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    protected override async Task OnParametersSetAsync()
    {
        Resolve();
        if (!AiOn) return;
        var key = _sunday.ToString("yyyy-MM-dd");
        if (key == _loadedKey && _summary is not null) return;
        _loadedKey = key;
        CancelPoll(); // moved to a different week — drop any in-flight poll for the old one
        await Load();
    }

    /// <summary>Pick the active week (from the URL date, else the current week) and work out the
    /// neighbouring Sundays — bounded so "earlier" stops once there are no older stories to write up.</summary>
    private void Resolve()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        _currentSunday = DeliverySunday(today);
        _sunday = DateOnly.TryParse(Date, out var d) ? DeliverySunday(d) : _currentSunday;
        if (_sunday > _currentSunday) _sunday = _currentSunday; // never the future
        _isLatest = _sunday >= _currentSunday;

        var oldest = State.EditionDates.Count > 0 ? State.EditionDates[^1].Date : (DateOnly?)null;
        _prevSunday = oldest is { } m && m < WeekStart ? _sunday.AddDays(-7) : null;
        _nextSunday = _isLatest ? null : _sunday.AddDays(7);
    }

    private async Task Load()
    {
        _error = null;
        _loading = true;
        _summary = null;
        try { _summary = await Api.GetWeeklyEditionAsync(_isLatest ? null : _sunday); }
        catch (ApiException ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private async Task Generate()
    {
        // Remember the copy we're replacing: a regenerate must wait for a *newer* result, not return the
        // stale cached row the first poll would otherwise see (else regenerate looks instant + unchanged).
        var previousAt = _summary?.GeneratedAt;
        _error = null; _summary = null;
        _loading = true;
        StateHasChanged();
        var since = DateTimeOffset.UtcNow;
        try { await Api.GenerateWeeklyEditionAsync(_isLatest ? null : _sunday); } // enqueue; runs in the background
        catch (ApiException ex) { _error = ex.Message; _loading = false; return; }
        await PollAsync(since, previousAt);
    }

    /// <summary>Polls the cached GET (and /activity) until a Weekly newer than <paramref name="previousAt"/>
    /// lands or the job ends without one. Generation runs server-side, so this survives navigation away and back.</summary>
    private async Task PollAsync(DateTimeOffset since, DateTimeOffset? previousAt)
    {
        CancelPoll();
        _pollCts = new CancellationTokenSource();
        var ct = _pollCts.Token;
        var deadline = since.AddMinutes(12);
        try
        {
            while (DateTimeOffset.UtcNow < deadline)
            {
                await Task.Delay(3500, ct);
                var dto = await Api.GetWeeklyEditionAsync(_isLatest ? null : _sunday);
                if (dto is not null && (previousAt is null || dto.GeneratedAt > previousAt))
                { _summary = dto; _loading = false; await InvokeAsync(StateHasChanged); return; }
                var activity = await Api.GetAiActivityAsync();
                if (!activity.Running.Contains("Weekly"))
                {
                    _error = FreshError(activity.LastError, "Weekly", since)
                        ?? "The Weekly couldn't be written — there may be no stories for this week.";
                    _loading = false; await InvokeAsync(StateHasChanged); return;
                }
            }
            _error = "Still writing after several minutes — check back shortly.";
            _loading = false; await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { /* navigated away or restarted */ }
        catch (Exception ex)
        {
            _error = (ex as ApiException)?.Message ?? "Something went wrong while waiting for The Weekly.";
            _loading = false; await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>Only surface the recorded error if it's from this run (matching kind, after we enqueued) —
    /// a small clock-skew buffer guards the comparison. Otherwise it's a stale error from a past attempt.</summary>
    private static string? FreshError(AiErrorDto? e, string kind, DateTimeOffset since) =>
        e is not null && e.Kind == kind && e.OccurredAt >= since.AddSeconds(-60) ? e.Message : null;

    private void CancelPoll() { _pollCts?.Cancel(); _pollCts?.Dispose(); _pollCts = null; }

    private void Go(DateOnly? sunday)
    {
        if (sunday is not { } s) return;
        Nav.NavigateTo(s >= _currentSunday ? "/weekly" : $"/weekly/{s:yyyy-MM-dd}");
    }

    private void GoLatest() => Nav.NavigateTo("/weekly");

    /// <summary>The Sunday a date's Monday–Saturday week is delivered on (the Sunday after its Saturday).</summary>
    private static DateOnly DeliverySunday(DateOnly d)
    {
        var daysSinceSaturday = ((int)d.DayOfWeek + 1) % 7; // Saturday = 0
        return d.AddDays(-daysSinceSaturday).AddDays(1);
    }

    // Build from integer day/year parts: a lone "d"/"y" in an interpolated DateOnly is the standard
    // short-date/year specifier, not day-of-month, which mangles the label.
    private static string RangeLabel(DateOnly start, DateOnly end) =>
        (start.Month == end.Month
            ? $"{start:MMMM} {start.Day}–{end.Day}, {end.Year}"
            : $"{start:MMM} {start.Day} – {end:MMM} {end.Day}, {end.Year}").ToUpperInvariant();

    public void Dispose()
    {
        State.Changed -= OnStateChanged;
        CancelPoll();
    }
}
