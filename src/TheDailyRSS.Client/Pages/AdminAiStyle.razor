@page "/settings/ai-style"
@attribute [Authorize]
@inherits OperationComponent
@inject ApiClient Api

<PageTitle>AI house style · The Daily RSS</PageTitle>

<SettingsShell Current="ai-style" Crumb="AI house style (admin)">
        <h1>AI house style</h1>
        <div class="tdr-settings-intro">
            The shared editorial voice prepended to every reader's <b>Daily briefing</b> and <b>The Weekly</b>.
            Set the persona and tone here — the structural rules (sections, citations, the Weekly's machinery)
            are fixed in code, and each reader's own interests are layered on top. Leave it blank to use the
            built-in default.
        </div>

        @if (_loaded)
        {
            <h2 class="tdr-subhead">House style <span class="tdr-tag">editable</span></h2>
            <textarea class="tdr-input" rows="6" style="max-width:720px; width:100%"
                      @bind="_value" @bind:event="oninput" placeholder="@_default"></textarea>
            <div class="tdr-hint">
                @(_isDefault ? "Currently using the built-in default (shown above as placeholder)." : "Currently using a custom house style.")
            </div>

            <div style="margin-top:14px; display:flex; gap:10px; align-items:center">
                <button class="tdr-btn" @onclick="Save" disabled="@Busy">save</button>
                <button class="tdr-btn ghost" @onclick="ResetToDefault" disabled="@(Busy || _isDefault)">reset to default</button>
                @if (_saved) { <span class="tdr-hint">↳ saved.</span> }
            </div>

            @if (Error is not null) { <div class="tdr-error">@Error</div> }

            <h2 class="tdr-subhead" style="margin-top:26px">Full prompt <span class="tdr-tag muted">read-only preview</span></h2>
            <div class="tdr-hint" style="margin-bottom:10px">
                Exactly what each reader's model receives, assembled as
                <b>house style</b> → <b>fixed rules</b> → <b>the reader's own interests</b>. Only the house style
                above is editable; the rest is fixed in code so an edit can't break generation.
            </div>

            <h3 class="tdr-promptlabel">Daily briefing</h3>
            <textarea class="tdr-input tdr-prompt-preview" rows="12" readonly>@Assemble(_dailyRules)</textarea>

            <h3 class="tdr-promptlabel">The Weekly</h3>
            <textarea class="tdr-input tdr-prompt-preview" rows="12" readonly>@Assemble(_weeklyRules)</textarea>
        }
</SettingsShell>

@code {
    private string _value = "";
    private string _default = "";
    private string _dailyRules = "";
    private string _weeklyRules = "";
    private bool _isDefault;
    private bool _loaded;
    private bool _saved;

    protected override async Task OnInitializedAsync()
    {
        await RunAsync(async () =>
        {
            var dto = await Api.GetAiHouseStyleAsync();
            _default = dto.Default;
            _dailyRules = dto.DailyRules;
            _weeklyRules = dto.WeeklyRules;
            Apply(dto);
        });
        _loaded = true;
    }

    private Task Save() => Persist(() => Api.UpdateAiHouseStyleAsync(_value));
    private Task ResetToDefault() => Persist(() => Api.UpdateAiHouseStyleAsync(null));

    private async Task Persist(Func<Task<AiHouseStyleDto>> call)
    {
        _saved = false;
        if (await RunAsync(async () => Apply(await call()))) _saved = true;
    }

    // Show a custom value in the box; when on the default, leave the box empty so the default
    // shows as placeholder and "save" of an untouched box keeps using the default.
    private void Apply(AiHouseStyleDto dto)
    {
        _isDefault = dto.IsDefault;
        _value = dto.IsDefault ? "" : dto.Value;
    }

    // Live preview of the assembled system prompt. The effective house style is what they've typed,
    // or the default when the box is empty.
    private string Assemble(string rules)
    {
        var houseStyle = string.IsNullOrWhiteSpace(_value) ? _default : _value.Trim();
        return $"{houseStyle}\n\n{rules}\n\n[Each reader's own interests are appended here.]";
    }
}
