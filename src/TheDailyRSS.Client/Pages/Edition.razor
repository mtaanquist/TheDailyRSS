@page "/"
@page "/{Slug}"
@page "/{Slug}/{Date}"
@attribute [Authorize]
@implements IDisposable
@inject ApiClient Api
@inject AppState State
@inject NavigationManager Nav
@inject AuthService Auth

<PageTitle>@(_edition?.CategoryName ?? "Front page") · The Daily RSS</PageTitle>

@if (_edition is null)
{
    <div class="tdr-masthead">
        <div class="tdr-masthead-title">The Daily RSS</div>
    </div>
    <div class="tdr-edition-body"><p style="font-style:italic; color:var(--ink-3)">@(_error ?? "Going to press…")</p></div>
}
else
{
    var ed = _edition;
    <header class="tdr-masthead">
        <div class="tdr-masthead-meta">
            <span>@ed.VolumeLabel · @ed.IssueLabel</span>
            <span>@ed.DateLabel</span>
            @if (ShowUnread)
            {
                <span>Unread · @ed.UnreadTotal</span>
            }
        </div>
        <h1 class="tdr-masthead-title clickable" @onclick="Refresh" role="button" title="Refresh stories">The Daily RSS</h1>
        <div class="tdr-masthead-rule">
            <span>— @(ed.CategoryName ?? "from your feeds") —</span>
        </div>
    </header>

    @if (!Saved && !Hidden)
    {
        <div class="tdr-editionbar">
            <button class="tdr-navbtn" disabled="@(ed.PrevDate is null || _loading)"
                    @onclick="@(() => Navigate(ed.PrevDate))">← <span class="lbl">earlier</span></button>
            <span class="tdr-edition-date">@(ed.IsToday ? "TODAY'S EDITION" : ed.Date.ToString("MMM d, yyyy").ToUpperInvariant())</span>
            <button class="tdr-navbtn" disabled="@(ed.NextDate is null || _loading)"
                    @onclick="@(() => Navigate(ed.NextDate))"><span class="lbl">later</span> →</button>
            @if (!ed.IsToday)
            {
                <button class="tdr-navbtn" @onclick="GoLatest"><span class="lbl">latest</span> »</button>
            }
        </div>
    }

    @if (AiOn && !Saved && !Hidden)
    {
        <div class="tdr-aibar">
            <span class="tdr-aibar-label">AI briefings</span>
            <button class="tdr-navbtn @(_aiMode == AiSummaryKind.Daily ? "active" : "")"
                    @onclick="@(() => ToggleAi(AiSummaryKind.Daily))">this edition</button>
            <button class="tdr-navbtn @(_aiMode == AiSummaryKind.Weekly ? "active" : "")"
                    @onclick="@(() => ToggleAi(AiSummaryKind.Weekly))">The Weekly</button>
        </div>
        @if (_aiMode is { } mode)
        {
            <div class="tdr-ai-panel">
                @if (_aiLoading)
                {
                    <p class="tdr-ai-status">Composing your @(mode == AiSummaryKind.Weekly ? "weekly" : "daily") briefing… this can take a moment.</p>
                }
                else if (_aiError is not null)
                {
                    <div class="tdr-error">@_aiError</div>
                    <button class="tdr-btn" @onclick="GenerateAi">try again</button>
                }
                else if (_aiSummary is { } sum)
                {
                    <div class="tdr-ai-head">
                        <span>@(mode == AiSummaryKind.Weekly ? "The Weekly" : "Daily briefing") · @sum.ArticleCount stories · @sum.Model</span>
                        <button class="tdr-link" @onclick="GenerateAi">regenerate</button>
                    </div>
                    <div class="tdr-ai-content">@((MarkupString)MarkdownLite.ToHtml(sum.Content))</div>
                    <div class="tdr-hint">Generated @sum.GeneratedAt.LocalDateTime.ToString("MMM d, HH:mm") · AI can be wrong — check the originals.</div>
                }
                else
                {
                    <p class="tdr-ai-status">No @(mode == AiSummaryKind.Weekly ? "weekly" : "daily") briefing yet for this edition.</p>
                    <button class="tdr-btn" @onclick="GenerateAi">generate briefing</button>
                }
            </div>
        }
    }

    <div class="tdr-edition-body @(_loading ? "loading" : "")">
        <div class="tdr-toolbar">
            <span class="title">@(Saved ? "Read later" : Hidden ? "Hidden" : ed.CategoryName ?? (ed.IsToday ? "Today's stories" : "All stories"))</span>
            <span class="spacer"></span>
            @if (ShowUnread && !Hidden)
            {
                <label class="toggle">
                    <span class="tdr-toggle @(Unread ? "on" : "")"><span class="knob"></span></span>
                    <input type="checkbox" checked="@Unread" @onchange="ToggleUnread" hidden />
                    Unread only
                </label>
                @if (!Saved && (ed.Lead is not null || ed.Articles.Count > 0))
                {
                    <button class="tdr-link muted" @onclick="MarkAllRead">mark all read</button>
                }
            }
        </div>

        @if (ed.Lead is null && ed.Articles.Count == 0)
        {
            <div class="tdr-empty">
                <div class="tdr-empty-mark">∅</div>
                <h1 class="tdr-empty-title">@(EmptyTitle())</h1>
                <p class="tdr-empty-sub">@(EmptySub())</p>
                @if (State.Categories.Count == 0 || State.Categories.All(c => c.FeedCount == 0))
                {
                    <button class="tdr-btn" @onclick="() => _showAdd = true">+ subscribe to a feed</button>
                }
            </div>
        }
        else
        {
            @if (ed.Lead is { } lead)
            {
                <article class="tdr-lead">
                    <div class="tdr-kicker">
                        <span class="tdr-lead-flag">Lead Story</span>
                        <span>@lead.FeedTitle</span>
                        <span>@ArticleCard.Relative(lead.PublishedAt)</span>
                        <span style="margin-left:auto; display:inline-flex; align-items:center; gap:4px">
                            <StarButton Saved="lead.IsSaved" SavedChanged="@(s => OnSave((lead.Id, s)))" />
                            <HideButton Hidden="lead.IsHidden" HiddenChanged="@(h => OnHide((lead.Id, h)))" />
                        </span>
                    </div>
                    <h1 @onclick="@(() => Open(lead.Id))">@lead.Title</h1>
                    <div class="tdr-lead-grid">
                        <NewsImage Src="@lead.ImageUrl" Height="200" Label="lead photo" />
                        <div>
                            @if (!string.IsNullOrWhiteSpace(lead.Summary))
                            {
                                <div class="tdr-standfirst">@Truncate(lead.Summary, 360)</div>
                            }
                            <a class="tdr-link" href="/article/@lead.Id">read the full story →</a>
                        </div>
                    </div>
                </article>
            }

            @if (IsFrontPage && ed.Sections.Count > 0)
            {
                @foreach (var sec in ed.Sections)
                {
                    <section class="tdr-section">
                        <div class="tdr-section-head" style="--cat:@sec.Color">
                            <h2 class="tdr-section-name">@sec.Name</h2>
                            <a class="tdr-link" href="@SectionUrl(sec.CategoryId)">more in @sec.Name →</a>
                        </div>
                        <div class="tdr-grid">
                            @foreach (var a in sec.Articles)
                            {
                                <div class="tdr-grid-item">
                                    <ArticleCard Article="a" OnSaveToggled="OnSave" OnHideToggled="OnHide" />
                                </div>
                            }
                        </div>
                    </section>
                }
            }
            else
            {
                <div class="tdr-grid">
                    @foreach (var a in ed.Articles)
                    {
                        <div class="tdr-grid-item">
                            <ArticleCard Article="a" OnSaveToggled="OnSave" OnHideToggled="OnHide" />
                        </div>
                    }
                </div>
            }
        }
    </div>

    <AddFeedDialog @bind-Visible="_showAdd" Categories="State.Categories" OnAdded="ReloadAll" />
}

@code {
    [Parameter] public string? Slug { get; set; }
    [Parameter] public string? Date { get; set; }
    [SupplyParameterFromQuery(Name = "src")] public Guid? Src { get; set; }
    [SupplyParameterFromQuery(Name = "unread")] public bool Unread { get; set; }

    private EditionDto? _edition;
    private string? _error;
    private bool _showAdd;
    private bool _loading;
    private string _loadedKey = "";
    private Guid? _categoryId;

    private AiSummaryKind? _aiMode;
    private AiSummaryDto? _aiSummary;
    private bool _aiLoading;
    private string? _aiError;

    private bool AiOn => Auth.CurrentUser?.Preferences.AiEnabled ?? false;

    private bool ShowUnread => Auth.CurrentUser?.Preferences.ShowUnread ?? true;
    /// <summary>The unread filter only applies when the reader has unread display turned on.</summary>
    private bool EffectiveUnread => Unread && ShowUnread;

    /// <summary>"saved" is a reserved slug for the cross-date saved view.</summary>
    private bool Saved => string.Equals(Slug, "saved", StringComparison.OrdinalIgnoreCase);
    /// <summary>"hidden" is a reserved slug for the cross-date list of dismissed stories.</summary>
    private bool Hidden => string.Equals(Slug, "hidden", StringComparison.OrdinalIgnoreCase);
    /// <summary>The unfiltered front page renders a curated bit of every category.</summary>
    private bool IsFrontPage => _categoryId is null && Src is null && !Saved && !Hidden;
    private DateOnly? CurrentDate => DateOnly.TryParse(Date, out var d) ? d : null;
    /// <summary>The section slug for the page we're on ("today", "saved", "hidden", or a category slug).</summary>
    private string CurrentSlug => Saved ? "saved" : Hidden ? "hidden" : string.IsNullOrEmpty(Slug) ? "today" : Slug!;

    protected override void OnInitialized() => State.ReloadRequested += Refresh;

    /// <summary>Re-pull every feed server-side, then reload the edition in place.</summary>
    private async Task Refresh()
    {
        _loading = true;
        StateHasChanged();
        try { await Api.RefreshAllFeedsAsync(); }
        catch (ApiException) { /* still re-fetch what we have */ }
        await State.RefreshAsync();
        await Load();
        StateHasChanged();
    }

    protected override async Task OnParametersSetAsync()
    {
        var key = $"{Slug}|{Date}|{Src}|{Unread}";
        if (key == _loadedKey && _edition is not null) return;
        _loadedKey = key;
        await Load();
    }

    private async Task Load()
    {
        _error = null;
        _loading = true;
        try
        {
            await State.EnsureLoadedAsync();
            _categoryId = ResolveCategoryId();
            // Fetch into a local and only swap in on success, so the current edition
            // stays on screen during navigation (no collapse / scroll jump).
            EditionDto? result;
            if (Saved)
                result = await Api.GetEditionAsync(DateOnly.FromDateTime(DateTime.Today), null, Src, saved: true, EffectiveUnread);
            else if (Hidden)
                result = await Api.GetEditionAsync(DateOnly.FromDateTime(DateTime.Today), null, Src, saved: false, unreadOnly: false, hidden: true);
            else if (CurrentDate is { } d)
                result = await Api.GetEditionAsync(d, _categoryId, Src, saved: false, EffectiveUnread);
            else
                result = await Api.GetLatestEditionAsync(_categoryId, Src, EffectiveUnread);

            _edition = result;
            // The edition changed underneath us — collapse any open AI briefing.
            _aiMode = null; _aiSummary = null; _aiError = null; _aiLoading = false;
            // Surface the date in the sticky mobile header (compact, e.g. "Mon · May 25").
            State.SetHeaderDate(!Saved && !Hidden && result is { } e ? e.Date.ToString("ddd · MMM d, yyyy") : null);
        }
        catch (ApiException ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    public void Dispose()
    {
        State.ReloadRequested -= Refresh;
        State.SetHeaderDate(null);
    }

    /// <summary>Maps the URL slug to a category id; null for the front page / saved / unknown.</summary>
    private Guid? ResolveCategoryId() =>
        string.IsNullOrEmpty(Slug) || Slug is "today" or "saved" or "hidden"
            ? null
            : State.Categories.FirstOrDefault(c => string.Equals(c.Slug, Slug, StringComparison.OrdinalIgnoreCase))?.Id;

    private void Open(Guid id) => Nav.NavigateTo($"/article/{id}");

    private void Navigate(DateOnly? date)
    {
        if (date is null) return;
        Nav.NavigateTo(WithQuery(PathFor(CurrentSlug, date)));
    }

    private void GoLatest() => Nav.NavigateTo(WithQuery(PathFor(CurrentSlug, null)));

    private string SectionUrl(Guid catId)
    {
        var slug = State.Categories.FirstOrDefault(c => c.Id == catId)?.Slug ?? "today";
        return WithQuery(PathFor(slug, CurrentDate));
    }

    /// <summary>Builds a reader URL: "/" or "/today/{date}" for the front page,
    /// "/saved" for saved, "/{slug}" or "/{slug}/{date}" for a section.</summary>
    private static string PathFor(string slug, DateOnly? date) => slug switch
    {
        "saved" => "/saved",
        "hidden" => "/hidden",
        "today" => date is null ? "/" : $"/today/{date:yyyy-MM-dd}",
        _ => date is null ? $"/{slug}" : $"/{slug}/{date:yyyy-MM-dd}",
    };

    private string WithQuery(string path)
    {
        var q = new List<string>();
        if (Src is { } s) q.Add($"src={s}");
        if (Unread) q.Add("unread=true");
        return path + (q.Count > 0 ? "?" + string.Join("&", q) : "");
    }

    private void ToggleUnread()
    {
        Unread = !Unread;
        Nav.NavigateTo(WithQuery(PathFor(CurrentSlug, CurrentDate)));
    }

    private async Task OnSave((Guid Id, bool Saved) e)
    {
        await Api.SetSavedAsync(e.Id, e.Saved);
        if (Saved && !e.Saved) { await Load(); return; }
        if (_edition is null) return;
        ArticleSummaryDto? lead = _edition.Lead is { } l && l.Id == e.Id ? l with { IsSaved = e.Saved } : _edition.Lead;
        var articles = _edition.Articles.Select(a => a.Id == e.Id ? a with { IsSaved = e.Saved } : a).ToList();
        var sections = _edition.Sections
            .Select(sec => sec with
            {
                Articles = sec.Articles.Select(a => a.Id == e.Id ? a with { IsSaved = e.Saved } : a).ToList(),
            })
            .ToList();
        _edition = _edition with { Lead = lead, Articles = articles, Sections = sections };
    }

    private async Task OnHide((Guid Id, bool Hidden) e)
    {
        await Api.SetHiddenAsync(e.Id, e.Hidden);
        await State.RefreshAsync();

        // The Hidden list shows only dismissed stories; un-hiding one drops it from the list.
        if (Hidden) { await Load(); return; }
        if (_edition is null) return;

        var ed = _edition;
        var pool = ed.Articles.Where(a => a.Id != e.Id).ToList();

        // If the lead was hidden, promote the next best story (prefer one with a photo).
        var lead = ed.Lead;
        if (lead is { } l && l.Id == e.Id)
            lead = pool.FirstOrDefault(a => a.ImageUrl is not null) ?? pool.FirstOrDefault();
        var rest = pool.Where(a => lead is null || a.Id != lead.Id).ToList();

        // Refill each front-page section from the day's remaining pool so the hidden
        // tile is replaced by the next story in that category (sizes stay as they were).
        var sections = ed.Sections
            .Select(sec =>
            {
                var inCat = rest.Where(a => a.CategoryId == sec.CategoryId).ToList();
                return sec with { Count = inCat.Count, Articles = inCat.Take(sec.Articles.Count).ToList() };
            })
            .Where(sec => sec.Articles.Count > 0)
            .ToList();

        _edition = ed with { Lead = lead, Articles = rest, Sections = sections };
    }

    // ── AI briefings ────────────────────────────────────────────────────
    private async Task ToggleAi(AiSummaryKind kind)
    {
        if (_aiMode == kind) { _aiMode = null; return; }
        _aiMode = kind;
        _aiSummary = null; _aiError = null;
        if (_edition is null) return;

        _aiLoading = true;
        try
        {
            _aiSummary = kind == AiSummaryKind.Weekly
                ? await Api.GetWeeklySummaryAsync(_edition.Date)
                : await Api.GetDailySummaryAsync(_edition.Date);
        }
        catch (ApiException ex) { _aiError = ex.Message; }
        finally { _aiLoading = false; }
    }

    private async Task GenerateAi()
    {
        if (_edition is null || _aiMode is not { } kind) return;
        _aiLoading = true; _aiError = null;
        StateHasChanged();
        try
        {
            _aiSummary = kind == AiSummaryKind.Weekly
                ? await Api.GenerateWeeklySummaryAsync(_edition.Date)
                : await Api.GenerateDailySummaryAsync(_edition.Date);
        }
        catch (ApiException ex) { _aiError = ex.Message; }
        finally { _aiLoading = false; }
    }

    private async Task MarkAllRead()
    {
        if (_edition is null || Saved) return;
        await Api.MarkEditionReadAsync(_edition.Date, _categoryId);
        await State.RefreshAsync();
        await Load();
    }

    private async Task ReloadAll()
    {
        await State.RefreshAsync();
        await Load();
    }

    private string EmptyTitle() => Saved ? "Nothing to read later"
        : Hidden ? "Nothing hidden"
        : State.Categories.Count == 0 || State.Categories.All(c => c.FeedCount == 0) ? "Your press is idle"
        : Unread ? "You're all caught up" : "No stories in this edition";

    private string EmptySub() => Saved ? "Tap the bookmark on an article and it'll wait for you here."
        : Hidden ? "Hide a story you're not interested in and it'll be listed here."
        : State.Categories.Count == 0 || State.Categories.All(c => c.FeedCount == 0) ? "Subscribe to a feed and the news will start printing."
        : Unread ? "Every story in this edition has been read." : "Try an earlier edition, or check back after the next refresh.";

    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max].TrimEnd() + "…";
}
