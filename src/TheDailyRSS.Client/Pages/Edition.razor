@page "/"
@page "/edition/{Date}"
@attribute [Authorize]
@inject ApiClient Api
@inject AppState State
@inject NavigationManager Nav

<PageTitle>@(_edition?.CategoryName ?? "Front page") · The Daily RSS</PageTitle>

@if (_edition is null)
{
    <div class="tdr-masthead">
        <div class="tdr-masthead-title">The Daily RSS</div>
    </div>
    <div class="tdr-main"><p style="font-style:italic; color:var(--ink-3)">@(_error ?? "Going to press…")</p></div>
}
else
{
    var ed = _edition;
    <header class="tdr-masthead">
        <div class="tdr-masthead-meta">
            <span>@ed.VolumeLabel · @ed.IssueLabel</span>
            <span>@ed.DateLabel</span>
            <span>Unread · @ed.UnreadTotal</span>
        </div>
        <h1 class="tdr-masthead-title">The Daily RSS</h1>
        <div class="tdr-masthead-rule">
            <span>— @(ed.CategoryName ?? "from your feeds") —</span>
        </div>
    </header>

    @if (!Saved)
    {
        <div class="tdr-editionbar">
            <button class="tdr-navbtn" disabled="@(ed.PrevDate is null || _loading)"
                    @onclick="@(() => Navigate(ed.PrevDate))">← earlier edition</button>
            <span class="tdr-edition-date">@(ed.IsToday ? "TODAY'S EDITION" : ed.Date.ToString("MMM d, yyyy").ToUpperInvariant())</span>
            <button class="tdr-navbtn" disabled="@(ed.NextDate is null || _loading)"
                    @onclick="@(() => Navigate(ed.NextDate))">later edition →</button>
            @if (!ed.IsToday)
            {
                <button class="tdr-navbtn" @onclick="GoLatest">latest »</button>
            }
        </div>
    }

    <div class="tdr-main @(_loading ? "loading" : "")">
        <div class="tdr-toolbar">
            <span class="title">@(Saved ? "Saved articles" : ed.CategoryName ?? (ed.IsToday ? "Today's stories" : "All stories"))</span>
            <span class="spacer"></span>
            <label class="toggle">
                <span class="tdr-toggle @(Unread ? "on" : "")"><span class="knob"></span></span>
                <input type="checkbox" checked="@Unread" @onchange="ToggleUnread" hidden />
                Unread only
            </label>
            @if (!Saved && (ed.Lead is not null || ed.Articles.Count > 0))
            {
                <button class="tdr-link muted" @onclick="MarkAllRead">mark all read</button>
            }
        </div>

        @if (ed.Lead is null && ed.Articles.Count == 0)
        {
            <div class="tdr-empty">
                <div class="tdr-empty-mark">∅</div>
                <h1 class="tdr-empty-title">@(EmptyTitle())</h1>
                <p class="tdr-empty-sub">@(EmptySub())</p>
                @if (State.Categories.Count == 0 || State.Categories.All(c => c.FeedCount == 0))
                {
                    <button class="tdr-btn" @onclick="() => _showAdd = true">+ subscribe to a feed</button>
                }
            </div>
        }
        else
        {
            @if (ed.Lead is { } lead)
            {
                <article class="tdr-lead">
                    <div class="tdr-kicker">
                        <span class="tdr-chip red">LEAD · @lead.FeedTitle</span>
                        <span>@ArticleCard.Relative(lead.PublishedAt)</span>
                        <span style="margin-left:auto">
                            <StarButton Saved="lead.IsSaved" SavedChanged="@(s => OnSave((lead.Id, s)))" />
                        </span>
                    </div>
                    <h1 @onclick="@(() => Open(lead.Id))">@lead.Title</h1>
                    <div class="tdr-lead-grid">
                        <NewsImage Src="@lead.ImageUrl" Height="200" Label="lead photo" />
                        <div>
                            @if (!string.IsNullOrWhiteSpace(lead.Summary))
                            {
                                <div class="tdr-standfirst">@Truncate(lead.Summary, 360)</div>
                            }
                            <a class="tdr-link" href="/article/@lead.Id">read the full story →</a>
                        </div>
                    </div>
                </article>
            }

            <div class="tdr-grid">
                @foreach (var a in ed.Articles)
                {
                    <div class="tdr-grid-item">
                        <ArticleCard Article="a" OnSaveToggled="OnSave" />
                    </div>
                }
            </div>
        }
    </div>

    <AddFeedDialog @bind-Visible="_showAdd" Categories="State.Categories" OnAdded="ReloadAll" />
}

@code {
    [Parameter] public string? Date { get; set; }
    [SupplyParameterFromQuery(Name = "cat")] public Guid? Cat { get; set; }
    [SupplyParameterFromQuery(Name = "saved")] public bool Saved { get; set; }
    [SupplyParameterFromQuery(Name = "unread")] public bool Unread { get; set; }

    private EditionDto? _edition;
    private string? _error;
    private bool _showAdd;
    private bool _loading;
    private string _loadedKey = "";

    protected override async Task OnParametersSetAsync()
    {
        var key = $"{Date}|{Cat}|{Saved}|{Unread}";
        if (key == _loadedKey && _edition is not null) return;
        _loadedKey = key;
        await Load();
    }

    private async Task Load()
    {
        _error = null;
        _loading = true;
        try
        {
            await State.EnsureLoadedAsync();
            // Fetch into a local and only swap in on success, so the current edition
            // stays on screen during navigation (no collapse / scroll jump).
            EditionDto? result = null;
            if (Saved)
                result = await Api.GetEditionAsync(DateOnly.FromDateTime(DateTime.Today), Cat, saved: true, Unread);
            else if (string.IsNullOrEmpty(Date))
                result = await Api.GetLatestEditionAsync(Cat, Unread);
            else if (DateOnly.TryParse(Date, out var d))
                result = await Api.GetEditionAsync(d, Cat, saved: false, Unread);
            else
                _error = "That edition date isn't valid.";

            if (result is not null) _edition = result;
        }
        catch (ApiException ex) { _error = ex.Message; }
        finally { _loading = false; }
    }

    private void Open(Guid id) => Nav.NavigateTo($"/article/{id}");

    private void Navigate(DateOnly? date)
    {
        if (date is null) return;
        Nav.NavigateTo(BuildUrl($"/edition/{date:yyyy-MM-dd}"));
    }

    private void GoLatest() => Nav.NavigateTo(BuildUrl("/"));

    private string BuildUrl(string path)
    {
        var q = new List<string>();
        if (Cat is { } c) q.Add($"cat={c}");
        if (Unread) q.Add("unread=true");
        return path + (q.Count > 0 ? "?" + string.Join("&", q) : "");
    }

    private void ToggleUnread()
    {
        Unread = !Unread;
        var path = string.IsNullOrEmpty(Date) ? "/" : $"/edition/{Date}";
        var q = new List<string>();
        if (Cat is { } c) q.Add($"cat={c}");
        if (Saved) q.Add("saved=true");
        if (Unread) q.Add("unread=true");
        Nav.NavigateTo(path + (q.Count > 0 ? "?" + string.Join("&", q) : ""));
    }

    private async Task OnSave((Guid Id, bool Saved) e)
    {
        await Api.SetSavedAsync(e.Id, e.Saved);
        if (Saved && !e.Saved) { await Load(); return; }
        if (_edition is null) return;
        ArticleSummaryDto? lead = _edition.Lead is { } l && l.Id == e.Id ? l with { IsSaved = e.Saved } : _edition.Lead;
        var articles = _edition.Articles.Select(a => a.Id == e.Id ? a with { IsSaved = e.Saved } : a).ToList();
        _edition = _edition with { Lead = lead, Articles = articles };
    }

    private async Task MarkAllRead()
    {
        if (_edition is null || Saved) return;
        await Api.MarkEditionReadAsync(_edition.Date, Cat);
        await State.RefreshAsync();
        await Load();
    }

    private async Task ReloadAll()
    {
        await State.RefreshAsync();
        await Load();
    }

    private string EmptyTitle() => Saved ? "Nothing saved yet"
        : State.Categories.Count == 0 || State.Categories.All(c => c.FeedCount == 0) ? "Your press is idle"
        : Unread ? "You're all caught up" : "No stories in this edition";

    private string EmptySub() => Saved ? "Star an article and it'll wait for you here."
        : State.Categories.Count == 0 || State.Categories.All(c => c.FeedCount == 0) ? "Subscribe to a feed and the news will start printing."
        : Unread ? "Every story in this edition has been read." : "Try an earlier edition, or check back after the next refresh.";

    private static string Truncate(string s, int max) => s.Length <= max ? s : s[..max].TrimEnd() + "…";
}
