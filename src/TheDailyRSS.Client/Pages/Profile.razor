@page "/settings/profile"
@attribute [Authorize]
@inherits OperationComponent
@inject ApiClient Api
@inject AuthService Auth

<PageTitle>Account &amp; preferences · The Daily RSS</PageTitle>

<SettingsShell Current="profile" Crumb="Account & preferences">
        @if (_user is { } user)
        {
            <h1>Your account</h1>
            <div class="tdr-settings-intro">
                member since @user.CreatedAt.ToString("MMMM yyyy")
            </div>

            <div style="display:flex; gap:16px; align-items:flex-start; padding-bottom:16px; border-bottom:1px solid var(--rule)">
                <div class="tdr-avatar" style="width:64px; height:64px; font-size:26px">@user.Initials</div>
                <div style="flex:1; display:grid; grid-template-columns:90px 1fr; gap:8px 12px; align-items:center; font-size:13px">
                    <div class="tdr-sidebar-label" style="margin:0">Name</div>
                    <div style="display:flex; gap:8px; align-items:center">
                        <input class="tdr-input" style="max-width:280px" @bind="_name" />
                        <button class="tdr-link" @onclick="SaveName" disabled="@(_name.Trim() == user.DisplayName || Busy)">save</button>
                    </div>
                    <div class="tdr-sidebar-label" style="margin:0">Email</div>
                    <div>
                        @user.Email
                        <button class="tdr-link" style="margin-left:8px" @onclick="() => _changingEmail = !_changingEmail">change</button>
                    </div>
                    <div class="tdr-sidebar-label" style="margin:0">Password</div>
                    <div>
                        ••••••••••
                        <button class="tdr-link" style="margin-left:8px" @onclick="() => _changingPw = !_changingPw">change</button>
                    </div>
                </div>
            </div>

            @if (_changingEmail)
            {
                <div class="tdr-folder" style="padding:14px; margin-top:14px; max-width:420px">
                    <div class="tdr-field">
                        <label>New email</label>
                        <input class="tdr-input" type="email" @bind="_newEmail" />
                    </div>
                    <div class="tdr-field">
                        <label>Current password</label>
                        <input class="tdr-input" type="password" @bind="_emailPw" />
                    </div>
                    <button class="tdr-btn" @onclick="ChangeEmail" disabled="@Busy">update email</button>
                    <div class="tdr-hint">You'll sign in with the new address from next time.</div>
                </div>
            }

            @if (_changingPw)
            {
                <div class="tdr-folder" style="padding:14px; margin-top:14px; max-width:420px">
                    <div class="tdr-field">
                        <label>Current password</label>
                        <input class="tdr-input" type="password" @bind="_currentPw" />
                    </div>
                    <div class="tdr-field">
                        <label>New password</label>
                        <input class="tdr-input" type="password" @bind="_newPw" />
                    </div>
                    <button class="tdr-btn" @onclick="ChangePassword" disabled="@Busy">update password</button>
                </div>
            }

            <div class="tdr-prefs-grid">
                <div>
                    <h2 style="font-weight:800; font-size:14px; margin-bottom:8px">Appearance</h2>
                    <div class="tdr-sidebar-label" style="margin:0 0 4px">Theme</div>
                    <div class="tdr-theme-swatch">
                        <div class="tdr-theme-opt newsprint @(Pref.Theme == ThemePreference.Newsprint ? "active" : "")"
                             @onclick="() => SetTheme(ThemePreference.Newsprint)"><span>Newsprint</span></div>
                        <div class="tdr-theme-opt evening @(Pref.Theme == ThemePreference.Evening ? "active" : "")"
                             @onclick="() => SetTheme(ThemePreference.Evening)"><span>Evening</span></div>
                        <div class="tdr-theme-opt auto @(Pref.Theme == ThemePreference.Auto ? "active" : "")"
                             @onclick="() => SetTheme(ThemePreference.Auto)"><span>Auto</span></div>
                    </div>
                    <div class="tdr-hint">Auto turns on the Evening edition after sunset (local 19:00).</div>
                </div>

                <div>
                    <h2 style="font-weight:800; font-size:14px; margin-bottom:8px">Reading</h2>
                    <div class="tdr-sidebar-label" style="margin:0 0 4px">Headline font</div>
                    <div style="display:flex; gap:6px; margin-bottom:12px">
                        @foreach (var (val, label) in Fonts)
                        {
                            <span class="tdr-theme-opt @(Pref.HeadlineFont == val ? "active" : "")" @onclick="() => SetFont(val)"
                                  style="font-family:@FontStack(val)">@label</span>
                        }
                    </div>
                    <div class="tdr-sidebar-label" style="margin:0 0 4px">Density</div>
                    <div style="display:flex; gap:6px; margin-bottom:12px">
                        @foreach (var (val, label) in Densities)
                        {
                            <span class="tdr-theme-opt @(Pref.Density == val ? "active" : "")" @onclick="() => SetDensity(val)">@label</span>
                        }
                    </div>

                    <div class="tdr-sidebar-label" style="margin:0 0 4px">Unread</div>
                    <label class="tdr-toggle-row" @onclick="() => SetShowUnread(!Pref.ShowUnread)">
                        <span class="tdr-toggle @(Pref.ShowUnread ? "on" : "")"><span class="knob"></span></span>
                        <span>Show unread counts &amp; filter</span>
                    </label>
                    <div class="tdr-hint">Turn off for a cleaner read. Stories you've opened are still tracked and dimmed.</div>

                    <div class="tdr-sidebar-label" style="margin:14px 0 4px">Pictures</div>
                    <label class="tdr-toggle-row" @onclick="() => SetHideImages(!Pref.HideImages)">
                        <span class="tdr-toggle @(Pref.HideImages ? "on" : "")"><span class="knob"></span></span>
                        <span>No pictures mode</span>
                    </label>
                    <div class="tdr-hint">Hide every image for a text-only read. Pictures are still fetched, so turning this back off brings them straight back.</div>
                </div>

                <div>
                    <h2 style="font-weight:800; font-size:14px; margin-bottom:8px">Weather</h2>
                    <div class="tdr-sidebar-label" style="margin:0 0 4px">Location</div>
                    <div style="display:flex; gap:8px; align-items:center; margin-bottom:6px">
                        <input class="tdr-input" style="max-width:240px" placeholder="e.g. Copenhagen"
                               @bind="_weatherQuery" @bind:event="oninput" @onkeydown="WeatherKeyDown" />
                        <button class="tdr-link" @onclick="SaveWeatherLocation" disabled="@(Busy || !WeatherChanged)">save</button>
                    </div>
                    @if (!string.IsNullOrEmpty(Pref.WeatherLocation))
                    {
                        <div class="tdr-hint" style="margin-top:0">Showing weather for <strong>@Pref.WeatherLocation</strong>.
                            <button class="tdr-link" style="margin-left:6px" @onclick="ClearWeatherLocation" disabled="@Busy">clear</button>
                        </div>
                    }
                    else
                    {
                        <div class="tdr-hint" style="margin-top:0">Set a town or city to see the local forecast.</div>
                    }

                    <div class="tdr-sidebar-label" style="margin:14px 0 4px">Masthead</div>
                    <label class="tdr-toggle-row" @onclick="() => SetShowWeather(!Pref.ShowWeather)">
                        <span class="tdr-toggle @(Pref.ShowWeather ? "on" : "")"><span class="knob"></span></span>
                        <span>Show weather at a glance</span>
                    </label>
                    <div class="tdr-hint">A small temperature &amp; conditions readout in the front-page masthead, linking to the day's forecast.</div>
                </div>
            </div>

            @if (_saved)
            {
                <div class="tdr-hint" style="margin-top:16px">↳ saved &amp; synced to every device.</div>
            }
            @if (Error is not null)
            {
                <div class="tdr-error">@Error</div>
            }
        }
</SettingsShell>

@code {
    private UserDto? _user;
    private PreferencesDto Pref => _user?.Preferences ?? new PreferencesDto();
    private string _name = "";
    private bool _changingPw;
    private string _currentPw = "";
    private string _newPw = "";
    private bool _changingEmail;
    private string _newEmail = "";
    private string _emailPw = "";
    private string _weatherQuery = "";
    private bool _saved;

    /// <summary>The location box differs from what's saved (so "save" is worth offering).</summary>
    private bool WeatherChanged =>
        _weatherQuery.Trim().Length > 0 &&
        !string.Equals(_weatherQuery.Trim(), Pref.WeatherLocation, StringComparison.OrdinalIgnoreCase);

    private static readonly (HeadlineFont, string)[] Fonts =
        [(HeadlineFont.PtSerif, "Source Serif"), (HeadlineFont.Newsreader, "Newsreader"), (HeadlineFont.Lora, "Lora")];
    private static readonly (ReadingDensity, string)[] Densities =
        [(ReadingDensity.Compact, "Compact"), (ReadingDensity.Balanced, "Balanced"), (ReadingDensity.Airy, "Airy")];

    protected override void OnInitialized()
    {
        _user = Auth.CurrentUser;
        _name = _user?.DisplayName ?? "";
        _weatherQuery = _user?.Preferences.WeatherLocation ?? "";
    }

    private async Task SaveName()
    {
        if (await RunAsync(async () =>
        {
            _user = await Api.UpdateProfileAsync(new UpdateProfileRequest { DisplayName = _name.Trim() });
            Auth.UpdateUser(_user!);
        }))
        {
            Flash();
        }
    }

    private async Task ChangeEmail()
    {
        if (await RunAsync(async () =>
        {
            _user = await Api.ChangeEmailAsync(new ChangeEmailRequest { NewEmail = _newEmail.Trim(), CurrentPassword = _emailPw });
            Auth.UpdateUser(_user!);
            _changingEmail = false; _newEmail = ""; _emailPw = "";
        }))
        {
            Flash();
        }
    }

    private async Task ChangePassword()
    {
        if (await RunAsync(async () =>
        {
            await Api.ChangePasswordAsync(new ChangePasswordRequest { CurrentPassword = _currentPw, NewPassword = _newPw });
            _changingPw = false; _currentPw = ""; _newPw = "";
        }))
        {
            Flash();
        }
    }

    private Task SetTheme(ThemePreference t) => SavePref(p => p.Theme = t);
    private Task SetFont(HeadlineFont f) => SavePref(p => p.HeadlineFont = f);
    private Task SetDensity(ReadingDensity d) => SavePref(p => p.Density = d);
    private Task SetShowUnread(bool v) => SavePref(p => p.ShowUnread = v);
    private Task SetHideImages(bool v) => SavePref(p => p.HideImages = v);
    private Task SetShowWeather(bool v) => SavePref(p => p.ShowWeather = v);

    private async Task WeatherKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && WeatherChanged) await SaveWeatherLocation();
    }

    private Task SaveWeatherLocation() => SaveWeather(_weatherQuery.Trim());
    private Task ClearWeatherLocation() => SaveWeather("");

    private async Task SaveWeather(string query)
    {
        if (await RunAsync(async () =>
        {
            _user = await Api.SetWeatherLocationAsync(query);
            Auth.UpdateUser(_user!);
            _weatherQuery = _user!.Preferences.WeatherLocation ?? "";
        }))
        {
            Flash();
        }
    }

    private async Task SavePref(Action<PreferencesDto> mutate)
    {
        // Clone via `with` so a newly-added preference can't be silently dropped here.
        var pref = Pref with { };
        mutate(pref);
        if (await RunAsync(async () =>
        {
            _user = await Api.UpdatePreferencesAsync(pref);
            Auth.UpdateUser(_user!);
        }))
        {
            Flash();
        }
    }

    private void Flash() { _saved = true; }

    private static string FontStack(HeadlineFont f) => f switch
    {
        HeadlineFont.Newsreader => "'Newsreader', serif",
        HeadlineFont.Lora => "'Lora', serif",
        _ => "'Source Serif 4', serif",
    };
}
