@page "/settings/keywords"
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>Filters · The Daily RSS</PageTitle>

<div class="tdr-breadcrumb" style="padding:12px 24px; border-bottom:1px solid var(--rule); margin:0">
    <a href="/">Home</a> › Settings › <b>Filters</b>
</div>

<div class="tdr-settings">
    <SettingsNav Current="keywords" />

    <div class="tdr-settings-main">
        <h1 style="font-weight:900; font-size:26px">Muted words</h1>
        <div style="font-style:italic; font-size:13px; color:var(--ink-2); margin-bottom:18px">
            Articles matching one of these terms are kept out of your editions — handy for things like
            “giveaway” or “where to buy”. A plain term matches whole words (so <code>buy</code> won't catch
            “buyer”); add <code>*</code> as a wildcard for partial matches (<code>*buy*</code> catches
            “buyer”, <code>deal*</code> catches “deals”). By default a term is checked anywhere in the
            article, including link addresses — so muting <code>amazon.com</code> hides most deals posts.
        </div>

        @if (_error is not null)
        {
            <div class="tdr-error">@_error</div>
        }

        <div class="tdr-folder" style="padding:14px; max-width:520px">
            <div class="tdr-field">
                <label>Mute a term</label>
                <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap">
                    <input class="tdr-input" style="max-width:240px" placeholder="e.g. giveaway"
                           @bind="_term" @bind:event="oninput" @onkeydown="OnKey" />
                    <select class="tdr-select" style="width:auto" @bind="_scope">
                        <option value="@KeywordScope.Everywhere">Anywhere in article</option>
                        <option value="@KeywordScope.TitleOnly">Title only</option>
                    </select>
                    <select class="tdr-select" style="width:auto" @bind="_sourceId">
                        <option value="">On every feed</option>
                        @foreach (var f in _feeds)
                        {
                            <option value="@f.SourceId">Only on @f.Title</option>
                        }
                    </select>
                    <button class="tdr-btn" @onclick="Add" disabled="@(_busy || string.IsNullOrWhiteSpace(_term))">mute</button>
                </div>
            </div>
        </div>

        @if (_items.Count == 0)
        {
            <div class="tdr-note" style="margin-top:16px">Nothing muted yet.</div>
        }
        else
        {
            <div class="tdr-folder" style="margin-top:16px; max-width:520px">
                @foreach (var k in _items)
                {
                    <div class="tdr-feedrow">
                        <div class="ttl">
                            <div>@k.Term</div>
                            <div class="err" style="color:var(--ink-3); font-style:italic">
                                @(k.Scope == KeywordScope.TitleOnly ? "title only" : "anywhere in article")
                                · @(k.SourceId is null ? "any feed" : $"only on {k.SourceTitle ?? "this feed"}")
                            </div>
                        </div>
                        <span class="spacer"></span>
                        <button class="tdr-link" @onclick="() => Remove(k)">✕</button>
                    </div>
                }
            </div>
        }

        <h1 style="font-weight:900; font-size:26px; margin-top:32px">Muted fields</h1>
        <div style="font-style:italic; font-size:13px; color:var(--ink-2); margin-bottom:18px">
            More precise than keywords: these mute by the structured tags the feed itself attaches
            (e.g. <code>category=guides</code> or <code>media:keywords=sponsored</code>). Add a rule
            from the article view by clicking <b>filter…</b> in the byline.
        </div>

        @if (_fields.Count == 0)
        {
            <div class="tdr-note">No field filters yet.</div>
        }
        else
        {
            <div class="tdr-folder" style="max-width:520px">
                @foreach (var f in _fields)
                {
                    <div class="tdr-feedrow">
                        <div class="ttl">
                            <div><b>@f.FieldKey</b> = @f.Value</div>
                            <div class="err" style="color:var(--ink-3); font-style:italic">
                                @(f.SourceId is null ? "any feed" : $"only on {f.SourceTitle ?? "this feed"}")
                            </div>
                        </div>
                        <span class="spacer"></span>
                        <button class="tdr-link" @onclick="() => RemoveField(f)">✕</button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<KeywordFilterDto> _items = [];
    private List<FieldFilterDto> _fields = [];
    private List<FeedDto> _feeds = [];
    private string _term = "";
    private string _sourceId = "";        // "" = every feed; otherwise the FeedSource id as string
    private KeywordScope _scope = KeywordScope.Everywhere;
    private bool _busy;
    private string? _error;

    protected override Task OnInitializedAsync() => Load();

    private async Task Load()
    {
        try
        {
            _items = await Api.GetKeywordsAsync();
            _fields = await Api.GetFieldFiltersAsync();
            _feeds = (await Api.GetFeedsAsync()).OrderBy(f => f.Title).ToList();
        }
        catch (ApiException ex) { _error = ex.Message; }
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Add();
    }

    private async Task Add()
    {
        if (string.IsNullOrWhiteSpace(_term)) return;
        _error = null;
        _busy = true;
        try
        {
            Guid? sourceId = Guid.TryParse(_sourceId, out var sid) ? sid : null;
            await Api.AddKeywordAsync(new CreateKeywordRequest
            {
                Term = _term.Trim(),
                Scope = _scope,
                SourceId = sourceId,
            });
            _term = "";
            await Load();
        }
        catch (ApiException ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task Remove(KeywordFilterDto k)
    {
        try
        {
            await Api.DeleteKeywordAsync(k.Id);
            await Load();
        }
        catch (ApiException ex) { _error = ex.Message; }
    }

    private async Task RemoveField(FieldFilterDto f)
    {
        try
        {
            await Api.DeleteFieldFilterAsync(f.Id);
            await Load();
        }
        catch (ApiException ex) { _error = ex.Message; }
    }
}
