@page "/article/{Id:guid}"
@attribute [Authorize]
@using System.Text.RegularExpressions
@inject ApiClient Api
@inject AppState State
@inject NavigationManager Nav

<PageTitle>@(_article?.Title ?? "Article") · The Daily RSS</PageTitle>

@if (_article is null)
{
    <p style="font-style:italic; color:var(--ink-3)">@(_error ?? "Fetching the story…")</p>
}
else
{
    var a = _article;
    <article class="tdr-article">
        <button class="tdr-link muted" @onclick="GoBack">← back to the edition</button>

        <div class="kicker" style="margin-top:14px">@a.CategoryName · @a.FeedTitle</div>
        <h1>@a.Title</h1>
        <div class="byline">
            @if (!string.IsNullOrWhiteSpace(a.Author))
            {
                <span>By @a.Author</span><span>·</span>
            }
            <span style="font-style:italic">@a.PublishedAt.ToLocalTime().ToString("dddd, MMMM d · HH:mm")</span>
            <span class="spacer"></span>
            <StarButton Saved="a.IsSaved" SavedChanged="ToggleSave" />
            <HideButton Hidden="a.IsHidden" HiddenChanged="ToggleHide" />
        </div>

        @if (!string.IsNullOrEmpty(a.ImageUrl))
        {
            <div class="hero"><img src="@a.ImageUrl" alt="" referrerpolicy="no-referrer" /></div>
        }

        <div class="content">
            @if (!string.IsNullOrWhiteSpace(a.ContentHtml))
            {
                @((MarkupString)Sanitize(a.ContentHtml, a.ImageUrl))
            }
            else if (!string.IsNullOrWhiteSpace(a.Summary))
            {
                <p>@a.Summary</p>
            }
            else
            {
                <p style="font-style:italic; color:var(--ink-2)">No preview text — read it at the source.</p>
            }
        </div>

        <div class="actions">
            <a class="tdr-btn" href="@a.Url" target="_blank" rel="noopener noreferrer">read at source ↗</a>
            <button class="tdr-link muted" @onclick="ToggleRead">@(a.IsRead ? "mark unread" : "mark read")</button>
        </div>

        @if (_neighbors is { } nb && (nb.Prev is not null || nb.Next is not null))
        {
            <nav class="tdr-article-nav">
                @if (nb.Prev is { } prev)
                {
                    <a class="prev" href="/article/@prev.Id">
                        <span class="dir"><Icon Name="arrow-left" Size="13" /> Previous</span>
                        <span class="hd">@prev.Title</span>
                    </a>
                }
                else
                {
                    <span></span>
                }
                @if (nb.Next is { } next)
                {
                    <a class="next" href="/article/@next.Id">
                        <span class="dir">Next <Icon Name="arrow-right" Size="13" /></span>
                        <span class="hd">@next.Title</span>
                    </a>
                }
            </nav>
        }
    </article>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ArticleDto? _article;
    private ArticleNeighborsDto? _neighbors;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        _article = null;
        _neighbors = null;
        _error = null;
        try
        {
            _article = await Api.GetArticleAsync(Id);
            if (!_article.IsRead)
            {
                await Api.SetReadAsync(Id, true);
                _article = _article with { IsRead = true };
                await State.RefreshAsync();
            }
            // Neighbours aren't needed for the first paint — load them after the story shows.
            _neighbors = await Api.GetArticleNeighborsAsync(Id);
        }
        catch (ApiException ex) { _error = ex.Message; }
    }

    private void GoBack() => Nav.NavigateTo("/");

    private async Task ToggleSave(bool saved)
    {
        await Api.SetSavedAsync(Id, saved);
        if (_article is not null) _article = _article with { IsSaved = saved };
    }

    private async Task ToggleHide(bool hidden)
    {
        await Api.SetHiddenAsync(Id, hidden);
        if (_article is not null) _article = _article with { IsHidden = hidden };
        await State.RefreshAsync();
    }

    private async Task ToggleRead()
    {
        if (_article is null) return;
        var next = !_article.IsRead;
        await Api.SetReadAsync(Id, next);
        _article = _article with { IsRead = next };
        await State.RefreshAsync();
    }

    /// <summary>Strip script/style/iframe so feed HTML can't run in our origin, then drop a
    /// leading body image that just repeats the hero (e.g. The Verge leads every post with one).</summary>
    private static string Sanitize(string html, string? heroUrl)
    {
        html = Regex.Replace(html, "<(script|style|iframe)[^>]*>.*?</\\1>", "",
            RegexOptions.IgnoreCase | RegexOptions.Singleline);
        return string.IsNullOrEmpty(heroUrl) ? html : StripDuplicateHero(html, heroUrl);
    }

    /// <summary>Removes the first body image that matches the hero — its wrapping &lt;figure&gt; if any,
    /// else the bare &lt;img&gt;. Matches on the path before the query string so resized/cropped
    /// variants of the same image still count as duplicates.</summary>
    private static string StripDuplicateHero(string html, string heroUrl)
    {
        var key = ImageKey(heroUrl);

        foreach (Match fig in Regex.Matches(html, "<figure\\b[^>]*>.*?</figure>",
                     RegexOptions.IgnoreCase | RegexOptions.Singleline))
        {
            var src = Regex.Match(fig.Value, "<img\\b[^>]*?\\bsrc\\s*=\\s*[\"']([^\"']+)[\"']", RegexOptions.IgnoreCase);
            if (src.Success && ImageKey(src.Groups[1].Value) == key)
                return html.Remove(fig.Index, fig.Length);
        }

        foreach (Match img in Regex.Matches(html, "<img\\b[^>]*>", RegexOptions.IgnoreCase))
        {
            var src = Regex.Match(img.Value, "\\bsrc\\s*=\\s*[\"']([^\"']+)[\"']", RegexOptions.IgnoreCase);
            if (src.Success && ImageKey(src.Groups[1].Value) == key)
                return html.Remove(img.Index, img.Length);
        }

        return html;
    }

    /// <summary>Normalizes an image URL to its path (dropping the query) for duplicate comparison.</summary>
    private static string ImageKey(string url)
    {
        var q = url.IndexOf('?');
        return (q >= 0 ? url[..q] : url).Trim().ToLowerInvariant();
    }
}
