@if (!string.IsNullOrEmpty(Src))
{
    <div class="tdr-img has-photo" style="height:@(Height)px">
        @* Eager on WebKit (its native lazy-loading doesn't fire inside .tdr-main); lazy elsewhere.
           A failed load is degraded to the placeholder by the global handler in app.js — an inline
           onerror= would be silently blocked by the strict CSP (no 'unsafe-inline'). *@
        <img src="@Src" alt="" loading="@(BrowserEnv.IsWebKit ? "eager" : "lazy")"
             decoding="async" referrerpolicy="no-referrer" />
    </div>
}
else
{
    <div class="tdr-img" style="height:@(Height)px">
        @if (!string.IsNullOrEmpty(Label))
        {
            <div class="ph"><span style="background:var(--paper); padding:2px 6px">@Label</span></div>
        }
    </div>
}

@code {
    [Parameter] public string? Src { get; set; }
    [Parameter] public int Height { get; set; } = 100;
    [Parameter] public string? Label { get; set; } = "photo";
}
