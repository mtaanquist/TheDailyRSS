@* Inline Lucide-style stroke icons (matches the sign-out SVG in Sidebar.razor). *@
<svg class="tdr-icon @Class" viewBox="0 0 24 24" width="@Size" height="@Size" fill="none"
     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    @(new MarkupString(Path(Name)))
</svg>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = "";
    [Parameter] public int Size { get; set; } = 16;
    [Parameter] public string? Class { get; set; }

    private static string Path(string name) => name switch
    {
        "chevron-right" => "<polyline points='9 18 15 12 9 6' />",
        "chevron-down" => "<polyline points='6 9 12 15 18 9' />",
        "arrow-left" => "<line x1='19' y1='12' x2='5' y2='12' /><polyline points='12 19 5 12 12 5' />",
        "arrow-right" => "<line x1='5' y1='12' x2='19' y2='12' /><polyline points='12 5 19 12 12 19' />",
        "bookmark" => "<path d='M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z' />",
        "eye-off" => "<path d='M17.94 17.94A10.07 10.07 0 0 1 12 20c-6.5 0-10-7-10-7a18.4 18.4 0 0 1 5.06-5.94M9.9 4.24A9.1 9.1 0 0 1 12 4c6.5 0 10 7 10 7a18.5 18.5 0 0 1-2.16 3.19' />"
            + "<path d='M9.88 9.88a3 3 0 1 0 4.24 4.24' /><line x1='2' y1='2' x2='22' y2='22' />",
        "plus" => "<line x1='12' y1='5' x2='12' y2='19' /><line x1='5' y1='12' x2='19' y2='12' />",
        "settings" => "<line x1='4' y1='21' x2='4' y2='14' /><line x1='4' y1='10' x2='4' y2='3' />"
            + "<line x1='12' y1='21' x2='12' y2='12' /><line x1='12' y1='8' x2='12' y2='3' />"
            + "<line x1='20' y1='21' x2='20' y2='16' /><line x1='20' y1='12' x2='20' y2='3' />"
            + "<line x1='1' y1='14' x2='7' y2='14' /><line x1='9' y1='8' x2='15' y2='8' /><line x1='17' y1='16' x2='23' y2='16' />",
        "newspaper" => "<path d='M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2' />"
            + "<path d='M18 14h-8' /><path d='M15 18h-5' /><path d='M10 6h8v4h-8z' />",
        _ => "",
    };
}
