@inject AuthService Auth
@inject NavigationManager Nav

<nav class="tdr-settings-nav">
    <div class="tdr-sidebar-label">Settings</div>
    <a class="@(Current == "profile" ? "active" : "")" href="/settings/profile">Preferences</a>
    <a class="@(Current == "feeds" ? "active" : "")" href="/feeds">Feeds</a>
    <a class="@(Current == "keywords" ? "active" : "")" href="/settings/keywords">Filters</a>
    <a class="@(Current == "ai" ? "active" : "")" href="/settings/ai">AI summaries</a>
    <a class="@(Current == "devices" ? "active" : "")" href="/settings/devices">Sync</a>
    @if (Auth.CurrentUser?.IsAdmin == true)
    {
        <a class="@(Current == "categories" ? "active" : "")" href="/settings/categories">Categories (admin)</a>
        <a class="@(Current == "ai-style" ? "active" : "")" href="/settings/ai-style">AI house style (admin)</a>
    }
    <a class="danger" @onclick="SignOut" @onclick:preventDefault="true" href="#">Sign out</a>
</nav>

@code {
    [Parameter] public string Current { get; set; } = "";

    private async Task SignOut()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login", replace: true);
    }
}
