@inject ApiClient Api

@if (Visible)
{
    <div class="tdr-overlay" @onclick="Close">
        <div class="tdr-modal" @onclick:stopPropagation="true">
            <div class="tdr-modal-head">
                <h2>Add a feed</h2>
                <button class="x" @onclick="Close">✕ CLOSE</button>
            </div>
            <hr />

            <div class="tdr-field">
                <label>URL or site</label>
                <input class="tdr-input" placeholder="https://www.theverge.com" @bind="_url" @bind:event="oninput"
                       @onkeydown="OnKey" />
                <div class="tdr-hint">↳ @(_exact ? "we'll use this URL exactly as the feed" : "we'll find the RSS feed automatically")</div>
                <label style="display:flex; align-items:center; gap:6px; font-size:11px; color:var(--ink-2); margin-top:6px; cursor:pointer">
                    <input type="checkbox" checked="@_exact" @onchange="OnExactChanged" />
                    this is already a feed URL — use it exactly
                </label>
            </div>

            <button class="tdr-btn ghost" @onclick="Detect" disabled="@(_busy || string.IsNullOrWhiteSpace(_url))">
                @(_detecting ? "finding…" : "find feed →")
            </button>

            @if (_error is not null)
            {
                <div class="tdr-error">@_error</div>
            }

            @if (_result is { Found: true })
            {
                <div class="tdr-preview">
                    <div class="row">
                        <div class="glyph">@_result.IconText</div>
                        <div style="flex:1">
                            <div style="font-weight:700">@_result.Title</div>
                            <div style="font-family:var(--typer); font-size:10px; color:var(--ink-3)">@_result.SiteUrl</div>
                        </div>
                        <span class="tdr-chip green">✓ FOUND</span>
                    </div>
                    @if (_result.RecentHeadlines.Length > 0)
                    {
                        <div style="margin-top:10px; font-style:italic; font-size:11px; color:var(--ink-2)">recent headlines:</div>
                        @foreach (var h in _result.RecentHeadlines)
                        {
                            <div style="font-size:12.5px; margin-top:3px">@h</div>
                        }
                    }
                </div>

                <div class="tdr-field" style="margin-top:14px">
                    <label>Name</label>
                    <input class="tdr-input" @bind="_title" @bind:event="oninput" placeholder="@_result.Title" />
                    <div class="tdr-hint">↳ shown in your sidebar — rename it, or leave it as the feed's own title</div>
                </div>

                <div class="tdr-field" style="margin-top:14px">
                    <label>Add to folder</label>
                    <div class="tdr-folder-chips">
                        @foreach (var c in Categories)
                        {
                            <button class="tdr-folder-chip @(c.Id == _categoryId ? "active" : "")"
                                    @onclick="() => _categoryId = c.Id">@c.Name</button>
                        }
                    </div>
                </div>
            }

            <div class="tdr-modal-actions">
                <button class="tdr-link muted" @onclick="Close">cancel</button>
                <button class="tdr-btn" @onclick="Subscribe"
                        disabled="@(_busy || _result is not { Found: true } || _categoryId is null)">
                    @(_subscribing ? "subscribing…" : "subscribe")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }
    [Parameter] public IReadOnlyList<CategoryDto> Categories { get; set; } = [];
    [Parameter] public Guid? DefaultCategoryId { get; set; }
    [Parameter] public EventCallback OnAdded { get; set; }

    private string _url = "";
    private string _title = "";
    private FeedDetectResult? _result;
    private Guid? _categoryId;
    private string? _error;
    private bool _detecting;
    private bool _subscribing;
    private bool _exact;
    private bool _busy => _detecting || _subscribing;

    protected override void OnParametersSet()
    {
        _categoryId ??= DefaultCategoryId ?? Categories.FirstOrDefault()?.Id;
    }

    private async Task OnKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Detect();
    }

    private void OnExactChanged(ChangeEventArgs e)
    {
        _exact = e.Value is true;
        _result = null; // mode changed — previous detection no longer applies
        _title = "";
        _error = null;
    }

    private async Task Detect()
    {
        if (string.IsNullOrWhiteSpace(_url)) return;
        _error = null;
        _result = null;
        _detecting = true;
        try
        {
            _result = await Api.DetectFeedAsync(new AddFeedRequest { Url = _url, CategoryId = _categoryId ?? Guid.Empty, Exact = _exact });
            // Pre-fill the name with the feed's own title; the reader can override it before subscribing.
            if (_result is { Found: true }) _title = _result.Title ?? "";
            if (_result is { Found: false })
                _error = _exact
                    ? "That URL isn't a valid RSS or Atom feed."
                    : "Couldn't find an RSS or Atom feed at that address.";
        }
        catch (ApiException ex) { _error = ex.Message; }
        finally { _detecting = false; }
    }

    private async Task Subscribe()
    {
        if (_result is not { Found: true } || _categoryId is null) return;
        _error = null;
        _subscribing = true;
        try
        {
            await Api.AddFeedAsync(new AddFeedRequest
            {
                Url = _result.FeedUrl ?? _url,
                CategoryId = _categoryId.Value,
                Exact = _exact,
                // An override only when it differs from the feed's own title — otherwise leave it null
                // so the source's title continues to apply.
                Title = string.IsNullOrWhiteSpace(_title) || _title.Trim() == _result.Title?.Trim() ? null : _title.Trim(),
            });
            await OnAdded.InvokeAsync();
            Reset();
            await VisibleChanged.InvokeAsync(false);
        }
        catch (ApiException ex) { _error = ex.Message; }
        finally { _subscribing = false; }
    }

    private async Task Close()
    {
        Reset();
        await VisibleChanged.InvokeAsync(false);
    }

    private void Reset()
    {
        _url = "";
        _title = "";
        _result = null;
        _error = null;
        _detecting = false;
        _subscribing = false;
        _exact = false;
    }
}
