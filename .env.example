# Copy to .env and adjust before `docker compose up`.

# Postgres password (used by both the db and the app connection string)
DB_PASSWORD=change-me-in-prod

# Host port the newspaper is served on
APP_PORT=8080

# IANA timezone that defines when a new "edition" starts (the daily cut-off)
EDITION_TZ=Europe/Copenhagen

# How often feeds are refreshed, in minutes
REFRESH_MINUTES=20

# Optional: a fixed JWT signing key. If blank, the app generates and persists one under /data.
JWT_KEY=
